#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Booyah PHP AST Instrumentor
 *
 * Transforms a PHP source tree to insert Booyah\Tracer hooks at:
 *   - Source reads (request inputs, superglobals)
 *   - Sink writes (echo, print, header, file output)
 *   - Transforms (sanitizers and string-manipulating functions)
 *
 * Usage:
 *   instrument --source-root /path/to/app --output-root /path/to/instrumented [--manifest manifest.json]
 *
 * The output tree mirrors the source tree exactly. Each instrumented file is
 * valid PHP. The Booyah\Tracer class must be autoloaded in the target app.
 *
 * Copy src/Tracer.php into the target app's autoload path, or require it via
 * a composer.json addition.
 */

$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../vendor/autoload.php',
];
foreach ($autoloadPaths as $path) {
    if (file_exists($path)) {
        require $path;
        break;
    }
}

use PhpParser\Error;
use PhpParser\NodeTraverser;
use PhpParser\NodeVisitor\CloningVisitor;
use PhpParser\ParserFactory;
use PhpParser\PrettyPrinter\Standard as PrettyPrinter;
use Booyah\InstrumentVisitor;

// --- CLI args ---
$opts = getopt('', ['source-root:', 'output-root:', 'manifest:', 'skip-dir:', 'universal']);

$sourceRoot   = realpath($opts['source-root'] ?? '') ?: null;
$outputRoot   = $opts['output-root'] ?? null;
$manifestPath = $opts['manifest'] ?? ($outputRoot !== null ? ($outputRoot . '/manifest.json') : null);
$universalMode = isset($opts['universal']);

if (!$sourceRoot || !$outputRoot) {
    fwrite(STDERR, "Usage: instrument --source-root <dir> --output-root <dir> [--manifest <file>] [--universal]\n");
    fwrite(STDERR, "  --universal  Instrument every class method entry (for full call graph tracing)\n");
    exit(1);
}

if (!is_dir($sourceRoot)) {
    fwrite(STDERR, "Source root does not exist: $sourceRoot\n");
    exit(1);
}

// Skip dirs — always skip Booyah/ to prevent Tracer instrumenting itself
$skipDirs = array_merge(
    ['vendor', 'generated', 'dev', '.git', 'node_modules', 'Booyah'],
    (array)($opts['skip-dir'] ?? [])
);

$parser = (new ParserFactory())->createForNewestSupportedVersion();
$printer = new PrettyPrinter(['shortArraySyntax' => true]);

$manifest = [
    'source_root' => $sourceRoot,
    'output_root' => $outputRoot,
    'generated_at' => date('c'),
    'files' => [],
];

$totalFiles = 0;
$instrumentedFiles = 0;
$parseErrors = 0;
$skippedFiles = 0;

$iterator = new RecursiveIteratorIterator(
    new RecursiveCallbackFilterIterator(
        new RecursiveDirectoryIterator($sourceRoot, FilesystemIterator::SKIP_DOTS),
        function (SplFileInfo $file, string $key, RecursiveDirectoryIterator $iterator) use ($skipDirs): bool {
            if ($iterator->hasChildren()) {
                return !in_array($file->getBasename(), $skipDirs, true);
            }
            return $file->getExtension() === 'php';
        }
    )
);

foreach ($iterator as $file) {
    /** @var SplFileInfo $file */
    $totalFiles++;
    $absolutePath = $file->getRealPath();
    $relativePath = substr($absolutePath, strlen($sourceRoot) + 1);
    $outputPath = $outputRoot . '/' . $relativePath;

    // Ensure output directory exists
    $outputDir = dirname($outputPath);
    if (!is_dir($outputDir) && !mkdir($outputDir, 0755, true) && !is_dir($outputDir)) {
        fwrite(STDERR, "Failed to create directory: $outputDir\n");
        continue;
    }

    $source = file_get_contents($absolutePath);

    // In universal mode: instrument everything. Otherwise use content filter.
    if (!$universalMode) {
        $hasInterestingContent = preg_match(
            '/getParam|getPost|getQuery|getContent|\$_GET|\$_POST|\$_REQUEST|\$_COOKIE|echo\s|print\s/i',
            $source
        );
        if (!$hasInterestingContent) {
            copy($absolutePath, $outputPath);
            $skippedFiles++;
            continue;
        }
    }

    try {
        $ast = $parser->parse($source);
        if ($ast === null) {
            copy($absolutePath, $outputPath);
            $parseErrors++;
            continue;
        }
    } catch (Error $e) {
        fwrite(STDERR, "  Parse error in $relativePath: " . $e->getMessage() . "\n");
        copy($absolutePath, $outputPath);
        $parseErrors++;
        continue;
    }

    // Clone AST for modification
    $traverser = new NodeTraverser();
    $traverser->addVisitor(new CloningVisitor());
    $modifiedAst = $traverser->traverse($ast);

    // Instrument
    $visitor = new InstrumentVisitor($relativePath, $universalMode);
    $traverser2 = new NodeTraverser();
    $traverser2->addVisitor($visitor);
    $instrumentedAst = $traverser2->traverse($modifiedAst);

    $injectionPoints = $visitor->getInjectionPoints();

    if (empty($injectionPoints)) {
        // No injections — copy unchanged
        copy($absolutePath, $outputPath);
        $skippedFiles++;
        continue;
    }

    // Prepend Tracer autoload require if not already present
    $instrumentedCode = "<?php\n// [booyah-instrumented]\n" .
        $printer->prettyPrint($instrumentedAst);

    file_put_contents($outputPath, $instrumentedCode);
    $instrumentedFiles++;

    $manifest['files'][] = [
        'source' => $relativePath,
        'output' => $relativePath,
        'injections' => $injectionPoints,
        'injection_count' => count($injectionPoints),
    ];

    if ($totalFiles % 500 === 0) {
        fprintf(STDERR, "  Progress: %d files processed, %d instrumented\n", $totalFiles, $instrumentedFiles);
    }
}

// Write manifest
if ($manifestPath) {
    $manifest['summary'] = [
        'total_files' => $totalFiles,
        'instrumented' => $instrumentedFiles,
        'skipped_no_interest' => $skippedFiles,
        'parse_errors' => $parseErrors,
    ];
    file_put_contents($manifestPath, json_encode($manifest, JSON_PRETTY_PRINT));
    fprintf(STDERR, "[+] Manifest written: %s\n", $manifestPath);
}

fprintf(STDERR, "\n=== Instrumentation Complete ===\n");
fprintf(STDERR, "  Total PHP files:      %d\n", $totalFiles);
fprintf(STDERR, "  Instrumented:         %d\n", $instrumentedFiles);
fprintf(STDERR, "  Skipped (unchanged):  %d\n", $skippedFiles);
fprintf(STDERR, "  Parse errors:         %d\n", $parseErrors);
fprintf(STDERR, "  Output:               %s\n", $outputRoot);
