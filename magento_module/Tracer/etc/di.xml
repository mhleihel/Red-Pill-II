<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Intercept all DB adapter reads and writes -->
    <!-- disabled: intercepting Pdo\Mysql directly creates a circular DI dependency:
         DbAdapterPlugin -> TaintLogger -> ResourceConnection -> Pdo\Mysql -> DbAdapterPlugin.
         DB taint tracking is handled by booyah_model_taint observers instead. -->
    <type name="Magento\Framework\DB\Adapter\Pdo\Mysql">
        <plugin name="booyah_db_taint"
                type="Booyah\Tracer\Plugin\DbAdapterPlugin"
                sortOrder="1"
                disabled="true"/>
    </type>

    <!-- Register HTTP probe values (bSRC_*) as taint sources at request entry point -->
    <type name="Magento\Framework\App\FrontController">
        <plugin name="booyah_request_taint"
                type="Booyah\Tracer\Plugin\RequestTaintPlugin"
                sortOrder="1"
                disabled="false"/>
    </type>

    <!-- Intercept session reads/writes -->
    <type name="Magento\Framework\Session\SessionManager">
        <plugin name="booyah_session_taint"
                type="Booyah\Tracer\Plugin\SessionPlugin"
                sortOrder="1"
                disabled="false"/>
    </type>

</config>
