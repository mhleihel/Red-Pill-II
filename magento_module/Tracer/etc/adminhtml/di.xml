<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- Explicit plugin registration for models whose abstract-class inheritance
         is not automatically resolved by Magento's DI compiler in the adminhtml area. -->

    <type name="Magento\Customer\Model\Customer">
        <plugin name="booyah_generic_model"
                type="Booyah\Tracer\Plugin\GenericModelPlugin"
                sortOrder="10"
                disabled="false"/>
    </type>

</config>
